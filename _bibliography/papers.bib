@inproceedings{venugopal2026dbmsolver,
  title={DBMSolver: A Training-free Diffusion Bridge Sampler for High-Quality Image-to-Image Translation},
  author={Venugopal, Sankarshana and Mostafavi, Mohammad and Choi, Jonghyun},
  booktitle={Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  year={2026},
  abbr={CVPR},
  selected={true},
  annotation={Accepted to CVPR 2026. Camera-ready submitted. Full paper and code repository will be made public soon.},
  preview={teaser-nodpm4.jpg},
  website={https://limsanky.github.io/projects/dbmsolver/},
  abstract={Diffusion-based image-to-image (I2I) translation excels in high-fidelity generation but suffers from slow sampling in state-of-the-art Diffusion Bridge Models (DBMs), often requiring dozens of function evaluations (NFEs). We introduce DBMSolver, a training-free sampler that exploits the semi-linear structure of DBM's underlying SDE and ODE via exponential integrators, yielding highly-efficient 1st- and 2nd-order solutions. This reduces NFEs by up to 5x while boosting quality (e.g., FID drops 53% on DIODE at 20 NFEs vs. 2nd-order baseline). Experiments on inpainting, stylization, and semantics-to-image tasks across resolutions up to 256x256 show DBMSolver sets new SOTA efficiency-quality tradeoffs, enabling real-world applicability.}
}

@inproceedings{venugopal2026falcon,
  title={FALCON: Fast Adaptive Lightweight Computation of Intensities and Events for Depth Estimation},
  author={Venugopal, Sankarshana and Mostafavi, Mohammad and Choi, Jonghyun},
  booktitle={Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR) Findings},
  year={2026},
  abbr={CVPR},
  selected={true},
  annotation={Accepted to CVPR 2026 Findings. Paper and code soon will be made public soon.},
  preview={Fig_pipeline1.jpg},
  website={https://limsanky.github.io/projects/falcon/},
  abstract={Event-based stereo depth estimation promises high-speed, robust perception under challenging conditions, but fusing events with intensity frames incurs heavy computational costs, hindering real-time deployment. We introduce FALCON: a Fast Adaptive Lightweight Computation framework that co-designs spiking neuron dynamics (via LIF neurons) with 1x1 convolutional event representations and a streamlined stereo backbone for efficient depth estimation. Our per-pixel spiking encoders capture temporal dynamics with over 1000x fewer FLOPs than prior modules, while our $\sigma$-matching heuristic optimizes event grouping to minimize blur. FALCON achieves state-of-the-art accuracy on DSEC (MAE 0.356) and MVSEC (MDE 11.7 cm) at 32.2 FPS and 72.8 FPS, respectively, establishing a new real-time benchmark for neuromorphic vision applications.}
}